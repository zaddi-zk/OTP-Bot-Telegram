# ============================================================================
# TELEGRAM BOT CONFIGURATION
# ============================================================================
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
USE_WEBHOOK=false
WEBHOOK_URL=https://your-domain.com
WEBHOOK_PATH=/telegram_webhook
TELEGRAM_API_BASE_URL=https://api.telegram.org/bot

# ============================================================================
# TWILIO CONFIGURATION (Voice Calls, SMS, OTP)
# ============================================================================
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=+1234567890
NGROK_URL=https://your-ngrok-url.ngrok-free.dev
NGROK_TOKEN=

# SMS Gateway (Twilio or Custom)
SMS_PROVIDER=twilio
SMS_API_URL=
SMS_API_KEY=

# ============================================================================
# TELEGRAM CHANNELS & ADMINS
# ============================================================================
MAIN_CHANNEL_URL=https://t.me/your_main_channel
BACKUP_CHANNEL_URL=https://t.me/your_backup_channel
MAIN_CHANNEL_ID=
BACKUP_CHANNEL_ID=
OWNER_ID=
ADMIN_ID=
DEVELOPER_IDS=

# ============================================================================
# VOICE & AUDIO (ElevenLabs or TTS)
# ============================================================================
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY_HERE
DEFAULT_ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2

# Voice Settings
VOICE_STABILITY=0.45
VOICE_SIMILARITY_BOOST=0.75
VOICE_STYLE=0.3
VOICE_USE_SPEAKER_BOOST=true
VOICE_SPEED_DEFAULT=1.0
VOICE_SPEED_FAST=1.1
VOICE_SPEED_SLOW=0.9
DEFAULT_VOICE_KEY=1

# ============================================================================
# PAYMENT & TRIAL
# ============================================================================
PAYMENT_BTC=YOUR_WALLET_ADDRESS_HERE
PAYMENT_ETH=YOUR_WALLET_ADDRESS_HERE
PAYMENT_LTC=YOUR_WALLET_ADDRESS_HERE
PAYMENT_USDT=YOUR_WALLET_ADDRESS_HERE
FREE_TRIAL_CALLS=5

# ============================================================================
# LIVE LISTEN (FastAPI WebSocket)
# ============================================================================
LIVE_LISTEN_URL=https://your-domain.com
LIVE_LISTEN_SECRET=your-secret-key-here
FASTAPI_PORT=5001

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================
ABSTRACT_API_KEY=

# ============================================================================
# SERVER & DEPLOYMENT
# ============================================================================
PORT=5000
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DEBUG=false

# Redis (optional, for rate limiting)
REDIS_URL=

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_CAPACITY=10
RATE_LIMIT_REFILL_RATE=1.0
RATE_LIMIT_MAX_VIOLATIONS=5
RATE_LIMIT_BASE_BAN_DURATION=300
RATE_LIMIT_MAX_BAN_DURATION=86400
RATE_LIMIT_BAN_ESCALATION_FACTOR=2.0
